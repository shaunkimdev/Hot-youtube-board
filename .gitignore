# secrets / cookies
pipeline/cookies.txt
*.env

# heavy / regenerated artifacts
pipeline/thumbs/
pipeline/*.mp4
pipeline/run.log
pipeline/candidates*.json
pipeline/longform_all.json

# /watch working cache under site/assets (videos & frames are huge & regenerable;
